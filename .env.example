# OpenAI API Key (Required for ChatGPT models e.g., gpt-4o-mini)
OPENAI_API_KEY=

# Google API Key (Required for Gemini models e.g., gemini-flash)
GOOGLE_API_KEY=

# Firecrawl API Key (Opsiyonel — web taramasının kalitesini artırır; yoksa klasik tarayıcıya düşülür)
FIRECRAWL_API_KEY=

# Flask oturum (session) imzalama anahtarı (login için gerekli)
# Tanımlı değilse her başlatmada rastgele üretilir — sunucu yeniden başladığında
# tüm oturumlar geçersiz olur. Kalıcı oturumlar için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Herkese açık demo dağıtımında (bkz. DEPLOY.md) günlük OpenAI/Gemini harcama tavanı
# (USD). Aşılınca chatbot LLM'e hiç gitmeden nazik bir "kota doldu" mesajı döner.
# Tanımlı değilse varsayılan 3.0 kullanılır. Yerel geliştirmede önemsizdir.
DAILY_BUDGET_USD=3.0

# Flask'ın kendi geliştirme sunucusunu debug modunda (interaktif hata konsolu
# açık) çalıştırır. SADECE yerel geliştirmede 1 yapın — production'da (internete
# açık) asla, uzaktan kod çalıştırma riski taşır. Production zaten gunicorn
# kullanır ve bu değişkeni okumaz.
FLASK_DEBUG=0
