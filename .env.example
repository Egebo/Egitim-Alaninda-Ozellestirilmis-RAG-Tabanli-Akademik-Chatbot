# OpenAI API Key (Required for ChatGPT models e.g., gpt-4o-mini)
OPENAI_API_KEY=

# Google API Key (Required for Gemini models e.g., gemini-flash)
GOOGLE_API_KEY=

# Firecrawl API Key (Opsiyonel — web taramasının kalitesini artırır; yoksa klasik tarayıcıya düşülür)
FIRECRAWL_API_KEY=

# Flask oturum (session) imzalama anahtarı (login için gerekli)
# Tanımlı değilse her başlatmada rastgele üretilir — sunucu yeniden başladığında
# tüm oturumlar geçersiz olur. Kalıcı oturumlar için: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
